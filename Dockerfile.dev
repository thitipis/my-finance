FROM node:20-alpine
WORKDIR /app

# Install deps (cached layer — only rebuilds when package.json changes)
COPY package.json package-lock.json* ./
RUN npm install

# Generate Prisma client into node_modules
# (schema is bind-mounted at runtime, but we need the client at startup)
COPY prisma ./prisma
RUN npx prisma generate

# Source code is bind-mounted at runtime via docker-compose.dev.yml
# No COPY . . needed here

EXPOSE 3000
CMD ["npm", "run", "dev"]
