generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Tier {
  free
  premium
}

enum Language {
  th
  en
}

enum FilingStatus {
  single
  married_no_income
  married_separate
  married_joint
}

enum GoalType {
  retirement
  emergency_fund
  investment
  home_car
  education
  custom
}

enum AuditAction {
  create
  update
  delete
}

enum RiskLevel {
  conservative
  moderate
  aggressive
}

// ─── User Tables ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?   @db.VarChar(255)
  passwordHash String    @map("password_hash")
  tier         Tier      @default(free)
  language     Language  @default(th)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  taxInputs        TaxInput[]
  deductionEntries TaxDeductionEntry[]
  goals            Goal[]
  insuranceData    InsuranceData?
  usageEvents      UsageEvent[]
  financialProfile FinancialProfile?
  riskAssessment      RiskAssessment?
  taxResults          TaxResult[]
  assessmentSessions  AssessmentSession[]
  aiSettings       AiSettings?
  financialPlan    FinancialPlan?
  portfolioAssets  PortfolioAsset[]
  lineageEvents    LineageEvent[]

  @@map("users")
}

model TaxInput {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  taxYearId      String       @map("tax_year_id")
  filingStatus   FilingStatus @default(single) @map("filing_status")
  annualSalary   Decimal      @default(0) @map("annual_salary") @db.Decimal(15, 2)
  bonus          Decimal      @default(0) @db.Decimal(15, 2)
  otherIncome    Decimal      @default(0) @map("other_income") @db.Decimal(15, 2)
  spouseIncome   Decimal      @default(0) @map("spouse_income") @db.Decimal(15, 2)
  withheldTax    Decimal      @default(0) @map("withheld_tax") @db.Decimal(15, 2)
  providentFund  Decimal      @default(0) @map("provident_fund") @db.Decimal(15, 2)
  socialSecurity Decimal      @default(0) @map("social_security") @db.Decimal(15, 2)
  numChildren    Int          @default(0) @map("num_children")
  numParents     Int          @default(0) @map("num_parents")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@unique([userId, taxYearId])
  @@map("tax_inputs")
}

model TaxDeductionEntry {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  taxYearId       String   @map("tax_year_id")
  deductionTypeId String   @map("deduction_type_id")
  amount          Decimal  @default(0) @db.Decimal(15, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear       TaxYear       @relation(fields: [taxYearId], references: [id])
  deductionType DeductionType @relation(fields: [deductionTypeId], references: [id])

  @@unique([userId, taxYearId, deductionTypeId])
  @@map("tax_deduction_entries")
}

model Goal {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  name                String    @db.VarChar(255)
  goalType            GoalType  @map("goal_type")
  targetAmount        Decimal   @map("target_amount") @db.Decimal(15, 2)
  currentAmount       Decimal   @default(0) @map("current_amount") @db.Decimal(15, 2)
  monthlyContribution Decimal   @default(0) @map("monthly_contribution") @db.Decimal(15, 2)
  annualReturnRate    Decimal   @default(0) @map("annual_return_rate") @db.Decimal(5, 2)
  targetDate          DateTime? @map("target_date") @db.Date
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model InsuranceData {
  id                           String   @id @default(uuid())
  userId                       String   @unique @map("user_id")
  // Annual premiums (kept for backward-compat; canonical source is FinancialProfile)
  lifeInsurancePremium         Decimal  @default(0) @map("life_insurance_premium") @db.Decimal(15, 2)
  healthInsurancePremium       Decimal  @default(0) @map("health_insurance_premium") @db.Decimal(15, 2)
  parentHealthInsurancePremium Decimal  @default(0) @map("parent_health_insurance_premium") @db.Decimal(15, 2)
  annuityInsurancePremium      Decimal  @default(0) @map("annuity_insurance_premium") @db.Decimal(15, 2)
  spouseLifeInsurancePremium   Decimal  @default(0) @map("spouse_life_insurance_premium") @db.Decimal(15, 2)
  // Coverage amounts / sum insured (for gap analysis)
  lifeCoverageAmount           Decimal  @default(0) @map("life_coverage_amount") @db.Decimal(15, 2)
  healthCoveragePerYear        Decimal  @default(0) @map("health_coverage_per_year") @db.Decimal(15, 2)
  parentHealthCoveragePerYear  Decimal  @default(0) @map("parent_health_coverage_per_year") @db.Decimal(15, 2)
  annuityCoverageAmount        Decimal  @default(0) @map("annuity_coverage_amount") @db.Decimal(15, 2)
  spouseLifeCoverageAmount     Decimal  @default(0) @map("spouse_life_coverage_amount") @db.Decimal(15, 2)
  hasAccidentInsurance         Boolean  @default(false) @map("has_accident_insurance")
  hasCriticalIllness           Boolean  @default(false) @map("has_critical_illness")
  hasDisabilityInsurance       Boolean  @default(false) @map("has_disability_insurance")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("insurance_data")
}

// ─── Config Tables (Admin-managed) ───────────────────────────────────────────

model TaxYear {
  id        String   @id @default(uuid())
  year      Int      @unique
  isActive  Boolean  @default(true) @map("is_active")
  labelTh   String   @map("label_th") @db.VarChar(50)
  labelEn   String   @map("label_en") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  taxBrackets       TaxBracket[]
  personalAllowance PersonalAllowance?
  deductionLimits   DeductionLimit[]
  taxInputs         TaxInput[]
  deductionEntries  TaxDeductionEntry[]
  taxResults        TaxResult[]

  @@map("tax_years")
}

model TaxBracket {
  id        String   @id @default(uuid())
  taxYearId String   @map("tax_year_id")
  minIncome Decimal  @map("min_income") @db.Decimal(15, 2)
  maxIncome Decimal? @map("max_income") @db.Decimal(15, 2)
  rate      Decimal  @db.Decimal(5, 2)
  sortOrder Int      @map("sort_order")

  taxYear TaxYear @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@map("tax_brackets")
}

model PersonalAllowance {
  id                    String  @id @default(uuid())
  taxYearId             String  @unique @map("tax_year_id")
  selfAmount            Decimal @map("self_amount") @db.Decimal(15, 2)
  spouseAmount          Decimal @map("spouse_amount") @db.Decimal(15, 2)
  childAmountPerChild   Decimal @map("child_amount_per_child") @db.Decimal(15, 2)
  parentAmountPerParent Decimal @map("parent_amount_per_parent") @db.Decimal(15, 2)
  maxParents            Int     @default(2) @map("max_parents")
  expenseDeductionRate  Decimal @map("expense_deduction_rate") @db.Decimal(5, 2)
  expenseDeductionMax   Decimal @map("expense_deduction_max") @db.Decimal(15, 2)

  taxYear TaxYear @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@map("personal_allowances")
}

model DeductionType {
  id            String  @id @default(uuid())
  code          String  @unique @db.VarChar(50)
  nameTh        String  @map("name_th") @db.VarChar(255)
  nameEn        String  @map("name_en") @db.VarChar(255)
  descriptionTh String? @map("description_th")
  descriptionEn String? @map("description_en")
  isActive      Boolean @default(true) @map("is_active")
  sortOrder     Int     @default(0) @map("sort_order")

  limits           DeductionLimit[]
  deductionEntries TaxDeductionEntry[]

  @@map("deduction_types")
}

model DeductionLimit {
  id                String   @id @default(uuid())
  taxYearId         String   @map("tax_year_id")
  deductionTypeId   String   @map("deduction_type_id")
  maxAmount         Decimal? @map("max_amount") @db.Decimal(15, 2)
  maxRateOfIncome   Decimal? @map("max_rate_of_income") @db.Decimal(5, 2)
  combinedCapGroup  String?  @map("combined_cap_group") @db.VarChar(50)
  combinedCapAmount Decimal? @map("combined_cap_amount") @db.Decimal(15, 2)
  isActive          Boolean  @default(true) @map("is_active")

  taxYear       TaxYear       @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  deductionType DeductionType @relation(fields: [deductionTypeId], references: [id])

  @@unique([taxYearId, deductionTypeId])
  @@map("deduction_limits")
}

model FeatureFlag {
  id             String   @id @default(uuid())
  key            String   @unique @db.VarChar(100)
  description    String?
  freeEnabled    Boolean  @default(false) @map("free_enabled")
  premiumEnabled Boolean  @default(true) @map("premium_enabled")
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedBy      String?  @map("updated_by")

  @@map("feature_flags")
}

// ─── Admin & Audit ───────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String   @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  auditLogs AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id          String      @id @default(uuid())
  adminUserId String      @map("admin_user_id")
  tableName   String      @map("table_name") @db.VarChar(100)
  recordId    String      @map("record_id")
  action      AuditAction
  oldValues   Json?       @map("old_values")
  newValues   Json?       @map("new_values")
  createdAt   DateTime    @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@map("audit_log")
}

model UsageEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type") @db.VarChar(100)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_events")
}

// ─── Financial Profile (Central User Data) ───────────────────────────────────

model FinancialProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // Personal
  filingStatus          FilingStatus @default(single) @map("filing_status")
  numChildren           Int          @default(0) @map("num_children")
  numParents            Int          @default(0) @map("num_parents")
  numDisabledDependents Int          @default(0) @map("num_disabled_dependents")

  // Income (annual baseline)
  annualSalary Decimal @default(0) @map("annual_salary") @db.Decimal(15, 2)
  bonus        Decimal @default(0) @db.Decimal(15, 2)
  otherIncome  Decimal @default(0) @map("other_income") @db.Decimal(15, 2)
  spouseIncome Decimal @default(0) @map("spouse_income") @db.Decimal(15, 2)
  withheldTax  Decimal @default(0) @map("withheld_tax") @db.Decimal(15, 2)

  // Payroll deductions
  socialSecurity      Decimal @default(0) @map("social_security") @db.Decimal(15, 2)
  providentFundRate   Decimal @default(0) @map("provident_fund_rate") @db.Decimal(5, 2)
  providentFundAmount Decimal @default(0) @map("provident_fund_amount") @db.Decimal(15, 2)

  // Insurance premiums (annual)
  lifeInsurancePremium         Decimal @default(0) @map("life_insurance_premium") @db.Decimal(15, 2)
  healthInsurancePremium       Decimal @default(0) @map("health_insurance_premium") @db.Decimal(15, 2)
  parentHealthInsurancePremium Decimal @default(0) @map("parent_health_insurance_premium") @db.Decimal(15, 2)
  annuityInsurancePremium      Decimal @default(0) @map("annuity_insurance_premium") @db.Decimal(15, 2)
  spouseLifeInsurancePremium   Decimal @default(0) @map("spouse_life_insurance_premium") @db.Decimal(15, 2)

  // Investment deductions (annual contributions)
  ltfAmount     Decimal @default(0) @map("ltf_amount") @db.Decimal(15, 2)
  rmfAmount     Decimal @default(0) @map("rmf_amount") @db.Decimal(15, 2)
  ssfAmount     Decimal @default(0) @map("ssf_amount") @db.Decimal(15, 2)
  thaiEsgAmount Decimal @default(0) @map("thai_esg_amount") @db.Decimal(15, 2)

  // Personal investment portfolio (current market value)
  goldAmount         Decimal @default(0) @map("gold_amount") @db.Decimal(15, 2)
  cryptoAmount       Decimal @default(0) @map("crypto_amount") @db.Decimal(15, 2)
  etfAmount          Decimal @default(0) @map("etf_amount") @db.Decimal(15, 2)
  thaiStockAmount    Decimal @default(0) @map("thai_stock_amount") @db.Decimal(15, 2)
  foreignStockAmount Decimal @default(0) @map("foreign_stock_amount") @db.Decimal(15, 2)
  otherInvestAmount  Decimal @default(0) @map("other_invest_amount") @db.Decimal(15, 2)

  // Liabilities
  totalDebt          Decimal  @default(0) @map("total_debt") @db.Decimal(15, 2)
  monthlyDebtPayment Decimal  @default(0) @map("monthly_debt_payment") @db.Decimal(15, 2)
  debtInterestRate   Decimal? @default(0) @map("debt_interest_rate") @db.Decimal(5, 2) // weighted avg annual interest %

  // Emergency fund & living expenses
  emergencyFundAmount  Decimal @default(0) @map("emergency_fund_amount") @db.Decimal(15, 2)
  monthlyExpenses      Decimal @default(0) @map("monthly_expenses") @db.Decimal(15, 2)

  // Savings accounts
  cashOnHand         Decimal @default(0) @map("cash_on_hand") @db.Decimal(15, 2)         // เงินสดในมือ
  savingsDeposit     Decimal @default(0) @map("savings_deposit") @db.Decimal(15, 2)      // เงินฝากออมทรัพย์
  fixedDeposit       Decimal @default(0) @map("fixed_deposit") @db.Decimal(15, 2)        // เงินฝากประจำ
  monthlySavingsGoal Decimal @default(0) @map("monthly_savings_goal") @db.Decimal(15, 2) // เป้าหมายออม/เดือน

  // Monthly budget breakdown (all monthly amounts)
  budgetHousing       Decimal @default(0) @map("budget_housing") @db.Decimal(15, 2)       // ที่อยู่อาศัย
  budgetFood          Decimal @default(0) @map("budget_food") @db.Decimal(15, 2)           // อาหาร
  budgetTransport     Decimal @default(0) @map("budget_transport") @db.Decimal(15, 2)      // การเดินทาง
  budgetUtilities     Decimal @default(0) @map("budget_utilities") @db.Decimal(15, 2)      // สาธารณูปโภค
  budgetHealthcare    Decimal @default(0) @map("budget_healthcare") @db.Decimal(15, 2)     // สุขภาพ
  budgetEntertainment Decimal @default(0) @map("budget_entertainment") @db.Decimal(15, 2)  // บันเทิง/ท่องเที่ยว
  budgetEducation     Decimal @default(0) @map("budget_education") @db.Decimal(15, 2)      // การศึกษา
  budgetPersonalCare  Decimal @default(0) @map("budget_personal_care") @db.Decimal(15, 2)  // ดูแลตัวเอง
  budgetOther         Decimal @default(0) @map("budget_other") @db.Decimal(15, 2)          // อื่น ๆ

  // Additional income
  taxRefundAmount Decimal @default(0) @map("tax_refund_amount") @db.Decimal(15, 2) // เงินคืนภาษี/ปี
  dividendIncome  Decimal @default(0) @map("dividend_income") @db.Decimal(15, 2)   // เงินปันผล จากหุ้น/ปี

  // Monthly investment targets
  monthlyInvestTax      Decimal? @map("monthly_invest_tax") @db.Decimal(15, 2)      // ลงทุนลดหย่อนภาษี/เดือน
  monthlyInvestPersonal Decimal? @map("monthly_invest_personal") @db.Decimal(15, 2) // ลงทุนส่วนตัว/เดือน

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_profiles")
}

// ─── Risk Assessment ──────────────────────────────────────────────────────────

model RiskAssessment {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  answers   Json      // [{questionId, answer, score}]
  score     Int       @default(0)
  riskLevel RiskLevel @map("risk_level")
  takenAt   DateTime  @default(now()) @map("taken_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("risk_assessments")
}

// ─── Assessment Sessions (history) ─────────────────────────────────────────────

model AssessmentSession {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  type    String   @db.VarChar(20) // "risk" | "personality" | "knowledge" | "goals"
  score   Int      @default(0)
  maxScore Int     @default(0) @map("max_score")
  result  Json     // type-specific summary: { level, label, ... }
  takenAt DateTime @default(now()) @map("taken_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("assessment_sessions")
}

// ─── Tax Results (full calculation history) ───────────────────────────────────

model TaxResult {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  taxYearId String @map("tax_year_id")

  // Snapshot of inputs used for this calculation
  inputSnapshot Json @map("input_snapshot")

  // Computed outputs
  totalIncome     Decimal @map("total_income") @db.Decimal(15, 2)
  totalDeductions Decimal @map("total_deductions") @db.Decimal(15, 2)
  netIncome       Decimal @map("net_income") @db.Decimal(15, 2)
  taxOwed         Decimal @map("tax_owed") @db.Decimal(15, 2)
  withheldTax     Decimal @map("withheld_tax") @db.Decimal(15, 2)
  taxRefund       Decimal @map("tax_refund") @db.Decimal(15, 2) // positive=refund, negative=pay more
  effectiveRate   Decimal @map("effective_rate") @db.Decimal(5, 2)
  marginalRate    Decimal @map("marginal_rate") @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear TaxYear @relation(fields: [taxYearId], references: [id])

  @@map("tax_results")
}

// ─── AI Settings (per user) ───────────────────────────────────────────────────

model AiSettings {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  toneLevel     Int      @default(3) @map("tone_level") // 1=gentle/encouraging, 5=direct/blunt
  customPrompt  String?  @map("custom_prompt") @db.Text
  // AI provider & model selection
  aiProvider    String   @default("gemini") @map("ai_provider")  // gemini | openai | ollama
  aiModel       String   @default("gemini-2.0-flash") @map("ai_model")
  apiToken      String?  @map("api_token") @db.Text              // user-supplied key (stored server-side only)
  ollamaBaseUrl String?  @default("http://localhost:11434") @map("ollama_base_url") @db.Text
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

// ─── Financial Plan ──────────────────────────────────────────────────────────

model FinancialPlan {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // Step 1 — Life stage
  currentAge       Int?    @map("current_age")
  maritalStatus    String? @default("single") @map("marital_status")
  numChildrenPlan  Int?    @default(0) @map("num_children_plan")

  // Step 2 — Goals
  retirementAge          Int?     @default(60) @map("retirement_age")
  monthlyRetirementNeeds Decimal? @map("monthly_retirement_needs") @db.Decimal(15, 2)
  hasHomeGoal            Boolean  @default(false) @map("has_home_goal")
  homePurchaseYears      Int?     @map("home_purchase_years")
  homeBudget             Decimal? @map("home_budget") @db.Decimal(15, 2)
  hasCarGoal             Boolean  @default(false) @map("has_car_goal")
  carPurchaseYears       Int?     @map("car_purchase_years")
  carBudget              Decimal? @map("car_budget") @db.Decimal(15, 2)
  hasEducationGoal       Boolean  @default(false) @map("has_education_goal")
  educationYears         Int?     @map("education_years")
  educationBudget        Decimal? @map("education_budget") @db.Decimal(15, 2)
  emergencyFundMonths    Int?     @default(6) @map("emergency_fund_months")

  // Step 3 — Planner (slider params)
  monthlyInvestable    Decimal? @map("monthly_investable") @db.Decimal(15, 2)
  currentSavings       Decimal? @default(0) @map("current_savings") @db.Decimal(15, 2)
  expectedReturn       Decimal? @default(7) @map("expected_return") @db.Decimal(5, 2)
  inflationRate        Decimal? @default(3) @map("inflation_rate") @db.Decimal(5, 2)
  targetWealthOverride Decimal? @map("target_wealth_override") @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_plans")
}

// ─── Admin System Prompt ──────────────────────────────────────────────────────

model AdminPrompt {
  id        String   @id @default(uuid())
  key       String   @unique @db.VarChar(50) // e.g. "main_system_prompt"
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("admin_prompts")
}


// ─── Portfolio Assets ────────────────────────────────────────────────────────

model PortfolioAsset {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  // Asset classification
  assetType      String?  @map("asset_type") // "thai_stock" | "thai_fund" | "thai_reit" | "us_etf" | "us_stock" | "crypto" | "gold" | "deposit" | "commodity" | "startup" | "custom"
  ticker         String?  // specific symbol e.g. "PTT", "VTI", "BTC"
  name           String   // display name / instrument name
  group          String   @default("other") // "thai" | "international" | "other"
  emoji          String   @default("💰")
  // Valuation
  currentValue     Decimal  @default(0) @map("current_value") @db.Decimal(15, 2)
  annualInvestment Decimal? @map("annual_investment") @db.Decimal(15, 2)  // how much invested per year (used for tax funds and personal saving plan)
  units            Decimal? @db.Decimal(20, 8)          // number of shares / coins / grams
  avgCostPerUnit   Decimal? @map("avg_cost_per_unit") @db.Decimal(15, 4)  // avg buy price per unit
  expectedReturn   Decimal? @map("expected_return") @db.Decimal(5, 2)     // annual expected return % (e.g. 7.0 = 7%/year)
  // Meta
  isBuiltIn      Boolean  @default(false) @map("is_built_in")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetType])
  @@map("portfolio_assets")
}

// ─── Instrument Catalog ──────────────────────────────────────────────────────

model InstrumentCatalog {
  id           String   @id @default(uuid())
  assetType    String   @map("asset_type") // same codes as PortfolioAsset.assetType
  ticker       String   // "PTT", "BTC", "VTI", "KMASTER"
  nameTh       String?  @map("name_th")
  nameEn       String?  @map("name_en")
  exchange     String?  // "SET", "MAI", "NYSE", "NASDAQ"
  provider     String?  // for funds: "Kasikorn", "SCB", "TISCO" ...
  sector       String?  // for stocks: "Energy", "Banking" ...
  isActive     Boolean  @default(true) @map("is_active")
  lastSyncedAt DateTime? @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([assetType, ticker])
  @@index([assetType])
  @@index([ticker])
  @@map("instrument_catalog")
}

// ─── Lineage (Life Timeline) ─────────────────────────────────────────────────

model LifeStageTemplate {
  id            String   @id @default(uuid())
  ageFrom       Int      @map("age_from")
  ageTo         Int      @map("age_to")
  titleTh       String   @map("title_th") @db.VarChar(100)
  descriptionTh String   @map("description_th") @db.Text
  icon          String   @db.VarChar(10)
  allocEquity   Int      @default(70) @map("alloc_equity")
  allocBond     Int      @default(20) @map("alloc_bond")
  allocCash     Int      @default(10) @map("alloc_cash")
  colorHex      String   @default("#6366f1") @map("color_hex") @db.VarChar(20)
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("life_stage_templates")
}

model LineageEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  age         Int
  eventYear   Int      @map("event_year")
  eventType   String   @map("event_type")
  impact      String   @default("neutral")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  isAuto      Boolean  @default(false) @map("is_auto")
  isAI        Boolean  @default(false) @map("is_ai")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("lineage_events")
}
